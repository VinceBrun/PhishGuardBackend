# Node.js
node_modules/

# dist IS ignored — Railway always builds from source via npm run build
# This ensures the latest compiled code is always used
dist/

# Logs — never commit log files
*.log
npm-debug.log*
yarn-debug.log*
logs/
!logs/.gitkeep

# Environment — NEVER commit .env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbbs.db

# Prisma
/prisma/*.db
/prisma/*.db-journal
