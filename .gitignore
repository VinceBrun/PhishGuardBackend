# Node.js
node_modules/

# dist is NOT ignored — Railway builds from source using npm run build
# but keeping dist/ committed means deploys work even without a build step
# dist/

# Logs — never commit log files
*.log
npm-debug.log*
yarn-debug.log*
logs/
!logs/.gitkeep

# Environment — NEVER commit .env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbbs.db

# Prisma
/prisma/*.db
/prisma/*.db-journal
