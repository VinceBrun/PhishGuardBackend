# ============================================================
# PhishGuard Backend — Environment Variables
# ============================================================
# Copy this to .env for local development.
# On Railway: set each variable in service → Variables tab.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_VERSION=v1

# ── DATABASE ─────────────────────────────────────────────────
# Railway sets this automatically via the PostgreSQL plugin.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/phishguard?schema=public

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex
JWT_REFRESH_EXPIRES_IN=30d

# ── URLS ─────────────────────────────────────────────────────
# FRONTEND_URL = your Vercel app (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
# BACKEND_URL = this Railway service public URL (no trailing slash)
BACKEND_URL=https://your-backend.railway.app

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=https://your-app.vercel.app

# ── EMAIL (SMTP) ─────────────────────────────────────────────
# Gmail: enable 2FA then create App Password at myaccount.google.com/apppasswords
# Leave blank for demo — app runs without email, campaigns just skip sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=noreply@phishguard.com
FROM_NAME=PhishGuard Security

# ── SECURITY ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── AI SERVICE (optional) ────────────────────────────────────
AI_API_URL=http://localhost:8000
